{
  "name": "campus-evaluation-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "shared/*"
  ],
  "scripts": {
    "install:all": "npm install",
    "build:logging": "npm run build -w shared/logging-package",
    "build:backend": "npm run build -w backend",
    "build:frontend": "npm run build -w frontend",
    "build": "npm run build:logging && npm run build:backend && npm run build:frontend",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "dev": "npm run dev:backend & npm run dev:frontend"
  }
}
