  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "http://localhost:5001/api/v1/auth/signup",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5001",
              "path": ["api", "v1", "auth", "signup"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Vinay\",\n  \"lastName\": \"Chauhan\",\n  \"email\": \"csh23012@glbitm.ac.in\",\n  \"password\": \"securepassword123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "http://localhost:5001/api/v1/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5001",
              "path": ["api", "v1", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"csh23012@glbitm.ac.in\",\n  \"password\": \"securepassword123\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "http://localhost:5001/api/v1/auth/logout",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5001",
